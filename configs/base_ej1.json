{
  "name": "ej1_base",
  "seed": 42,
  "data_path": "data/transactions.csv",
  "target_column": "big_model_fraud_probability",
  "preprocessing": "normalize",
  "split_train": 0.7,
  "split_val": 0.1,
  "split_test": 0.2,
  "activation": "tanh",
  "beta": 1.0,
  "architecture": [7, 1],
  "cost_function": "mse",
  "optimizer": "gradient_descent",
  "eta": 0.01,
  "training_mode": "online",
  "epochs": 200,
  "epsilon": 0.001,
  "metrics": ["mse", "accuracy"],
  "columns_to_ignore" : ["flagged_fraud", "timestamp","device_screen_resolution"]
}
