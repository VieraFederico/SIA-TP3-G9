{
  "name": "ej3_base",
  "seed": 42,
  "data_path": "data/more_data_digits.csv",
  "target_column": "label",
  "preprocessing": "standardize",
  "split_train": 0.8,
  "split_val": 0.1,
  "split_test": 0.1,
  "activation": "tanh",
  "beta": 1.0,
  "architecture": [784, 128, 64, 10],
  "cost_function": "categorical_cross_entropy",
  "optimizer": "adam",
  "eta": 0.001,
  "training_mode": "minibatch",
  "batch_size": 32,
  "epochs": 1000,
  "epsilon": 0.0001,
  "metrics": ["accuracy", "f1"]
}
