{
  "name": "fraud_nonlinear_tanh_v1",
  "seed": 42,
  "data_path": "data/transactions.csv",
  "target_column": "fraud",
  "preprocessing": ["standard_scaler"],
  "split": { "type": "hold_out", "train": 0.7, "val": 0.15, "test": 0.15 },
  "model_type": "simple_perceptron",
  "architecture": [10, 1],
  "activation": "tanh",
  "activation_beta": 1.0,
  "initializer": "xavier",
  "trainer": "online",
  "batch_size": 32,
  "loss": "mse",
  "optimizer": "gradient_descent",
  "learning_rate": 0.01,
  "optimizer_params": {},
  "max_epochs": 1000,
  "loss_threshold": 0.001,
  "early_stopping_patience": null,
  "metrics": ["mse", "accuracy", "precision", "recall", "f1"]
}
