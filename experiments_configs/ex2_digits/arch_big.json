{
  "name": "digits_mlp_arch_big",
  "seed": 42,
  "data_path": "data/digits.csv",
  "target_column": "label",
  "preprocessing": ["standard_scaler"],
  "split": { "type": "hold_out", "train": 0.7, "val": 0.15, "test": 0.15 },
  "model_type": "mlp",
  "architecture": [784, 256, 128, 64, 10],
  "activation": "relu",
  "activation_beta": 1.0,
  "initializer": "he",
  "trainer": "minibatch",
  "batch_size": 128,
  "loss": "categorical_cross_entropy",
  "optimizer": "adam",
  "learning_rate": 0.0005,
  "optimizer_params": { "beta1": 0.9, "beta2": 0.999, "epsilon": 1e-8 },
  "max_epochs": 200,
  "loss_threshold": null,
  "early_stopping_patience": 20,
  "metrics": ["mse", "accuracy", "f1"]
}
