{
  "name": "validation_nonlinear_tanh",
  "seed": 42,
  "data_path": "data/nonlinear_tanh.csv",
  "target_column": "y",
  "preprocessing": ["standard_scaler"],
  "split": { "type": "hold_out", "train": 0.7, "val": 0.15, "test": 0.15 },
  "model_type": "simple_perceptron",
  "architecture": [1, 1],
  "activation": "tanh",
  "activation_beta": 1.0,
  "initializer": "xavier",
  "trainer": "minibatch",
  "batch_size": 16,
  "loss": "mse",
  "optimizer": "gradient_descent",
  "learning_rate": 0.05,
  "optimizer_params": {},
  "max_epochs": 2000,
  "loss_threshold": null,
  "early_stopping_patience": 50,
  "metrics": ["mse", "accuracy"]
}
