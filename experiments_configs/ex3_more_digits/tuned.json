{
  "name": "more_digits_mlp_tuned",
  "seed": 42,
  "data_path": "data/more_data_digits.csv",
  "target_column": "label",
  "preprocessing": ["standard_scaler"],
  "split": { "type": "hold_out", "train": 0.7, "val": 0.15, "test": 0.15 },
  "model_type": "mlp",
  "architecture": [784, 256, 128, 10],
  "activation": "relu",
  "activation_beta": 1.0,
  "initializer": "he",
  "trainer": "minibatch",
  "batch_size": 64,
  "loss": "categorical_cross_entropy",
  "optimizer": "adam",
  "learning_rate": 0.0003,
  "optimizer_params": { "beta1": 0.9, "beta2": 0.999, "epsilon": 1e-8 },
  "max_epochs": 250,
  "loss_threshold": null,
  "early_stopping_patience": 25,
  "metrics": ["mse", "accuracy", "f1"]
}
